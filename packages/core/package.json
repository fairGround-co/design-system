{
  "name": "@fairground-co/core",
  "version": "0.1.0",
  "description": "fairGround design system core — the token contract, neutral reference theme, and generic brand-neutral React primitives (ESM + browser IIFE).",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/core.css",
    "./global": "./dist/core.global.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/build-lookbook.mjs",
    "lookbook": "node scripts/build-lookbook.mjs",
    "typecheck": "npm run build && tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fairground-co/design-system.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "0.25.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  }
}
